# Local Docker/runtime settings
APP_TIME_ZONE=America/New_York

# Gmail SMTP for registration group publish notifications.
# Use a Google App Password here, not your normal Google password.
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your-gmail-address@gmail.com
SPRING_MAIL_PASSWORD=your-google-app-password

# Keep disabled until real SMTP credentials are in place.
APP_EMAIL_NOTIFICATIONS_ENABLED=false
APP_EMAIL_NOTIFICATIONS_RECIPIENT_OVERRIDE=atwakuluk@email.msmary.edu
APP_EMAIL_NOTIFICATIONS_FROM=your-gmail-address@gmail.com
